{
  "name": "deepseek-usage-monitor",
  "version": "1.0.0",
  "description": "macOS menu bar tool for monitoring DeepSeek API usage and balance",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/settings.html dist/settings.html",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron . --dev\"",
    "electron:build": "vite build && cp src/settings.html dist/settings.html && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.deepseek.usage-monitor",
    "productName": "DeepSeek Usage Monitor",
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png"
    ]
  },
  "keywords": [
    "deepseek",
    "monitor",
    "electron",
    "menu-bar"
  ],
  "license": "MIT",
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.4",
    "concurrently": "^9.0.1",
    "electron": "^32.1.2",
    "electron-builder": "^25.1.7",
    "vite": "^5.4.8",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "electron-store": "^8.1.0",
    "vue": "^3.5.11",
    "vue-echarts": "^8.0.1"
  }
}
